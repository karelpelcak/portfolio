# Kontaktní formulář — odesílání přes Resend.
# Zkopíruj do .env.local pro lokální vývoj a nastav stejné hodnoty
# ve Vercel → Project → Settings → Environment Variables.

# API klíč z Resend (https://resend.com/api-keys), začíná "re_".
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Odesílatel — MUSÍ být na doméně ověřené v Resend (karelpelcak.eu).
# Doporučeno vyhradit adresu jen na odesílání, např. noreply@ nebo portfolio@.
CONTACT_FROM=Portfolio <noreply@karelpelcak.eu>

# Kam se poptávky doručí.
CONTACT_TO=pelcak.karel@gmail.com
